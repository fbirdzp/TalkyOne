# ==========================================
# TalkyOne 环境变量配置模板
# ==========================================
# 复制此文件为 .env.local 并填写真实值
# cp .env.example .env.local

# ------------------------------------------
# 基础配置
# ------------------------------------------

# 应用 URL (生产环境请修改为真实域名)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 环境 (development | production)
NODE_ENV=development

# ------------------------------------------
# 数据库配置
# ------------------------------------------

# SQLite (开发环境)
DATABASE_URL="file:./dev.db"

# PostgreSQL (生产环境 - Vercel Postgres 或 Supabase)
# DATABASE_URL="postgresql://user:password@localhost:5432/talkyone"

# ------------------------------------------
# NextAuth.js 配置
# ------------------------------------------

# NextAuth 密钥 (生成方式: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# NextAuth URL (与生产环境 NEXT_PUBLIC_APP_URL 相同)
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------
# 支付宝支付配置
# ------------------------------------------

# 应用 ID
ALIPAY_APP_ID="your-alipay-app-id"

# 商户私钥 (PKCS1 格式，需要转换为 PKCS8)
ALIPAY_PRIVATE_KEY="your-alipay-private-key"

# 支付宝公钥
ALIPAY_PUBLIC_KEY="your-alipay-public-key"

# 支付宝网关 (沙箱环境)
ALIPAY_GATEWAY="https://openapi.alipaydev.com/gateway.do"

# 支付宝网关 (生产环境 - 取消注释并使用)
# ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"

# 回调 URL (支付成功后支付宝会调用此 URL)
ALIPAY_NOTIFY_URL="${NEXT_PUBLIC_APP_URL}/api/payment/alipay/notify"

# 返回 URL (支付成功后用户浏览器会跳转到此 URL)
ALIPAY_RETURN_URL="${NEXT_PUBLIC_APP_URL}/api/payment/alipay/return"

# ------------------------------------------
# 微信支付配置
# ------------------------------------------

# 商户号
WECHAT_MCH_ID="your-wechat-merchant-id"

# 商户 API 证书序列号
WECHAT_CERT_SERIAL_NO="your-certificate-serial-number"

# 商户 API 私钥 (PEM 格式)
WECHAT_PRIVATE_KEY="your-wechat-private-key"

# 商户 API V3 密钥
WECHAT_API_V3_KEY="your-wechat-api-v3-key"

# AppID (微信公众号或小程序 ID)
WECHAT_APP_ID="your-wechat-app-id"

# 回调 URL (支付成功后微信会调用此 URL)
WECHAT_NOTIFY_URL="${NEXT_PUBLIC_APP_URL}/api/payment/wechat/notify"

# ------------------------------------------
# PayPal 支付配置
# ------------------------------------------

# PayPal 客户端 ID
PAYPAL_CLIENT_ID="your-paypal-client-id"

# PayPal 客户端密钥
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"

# PayPal 环境 (sandbox | live)
PAYPAL_ENV="sandbox"

# PayPal Webhook ID (在 PayPal 开发者后台创建 Webhook 后获取)
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"

# ------------------------------------------
# 文件上传配置 (Uploadthing)
# ------------------------------------------

# Uploadthing API 密钥
UPLOADTHING_SECRET_KEY="your-uploadthing-secret-key"

# ------------------------------------------
# 邮件服务配置 (Resend)
# ------------------------------------------

# Resend API 密钥
RESEND_API_KEY="your-resend-api-key"

# 发件人邮箱
EMAIL_FROM="noreply@talkyone.com"

# ------------------------------------------
# 其他配置
# ------------------------------------------

# 上传文件大小限制 (默认 10MB)
NEXT_PUBLIC_MAX_FILE_SIZE=10485760

# 每页显示记录数
NEXT_PUBLIC_PAGE_SIZE=20

# 调试模式 (true | false)
DEBUG=false
